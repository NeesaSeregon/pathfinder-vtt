DB_HOST=localhost
DB_PORT=5432
DB_USER=pathfinder
DB_PASSWORD=pathfinder
DB_NAME=pathfinder
JWT_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# Freno de fuerza bruta del login: cuenta SOLO los intentos fallidos, por
# pareja de email + IP. Entrar bien borra la cuenta.
# LOGIN_MAX_FALLOS=5
# LOGIN_BLOQUEO_SEGUNDOS=900

# --- Solo para el despliegue (docker-compose.prod.yml) ---
# NODE_ENV=production activa la cookie con secure:true, que EXIGE HTTPS:
# sin TLS por delante el navegador no la guarda y nadie podría entrar.
# NODE_ENV=production
# PORT=3000

# Carpeta donde se guardan los mapas subidos (dentro irá /mapas).
# Si no se define, se usa ./uploads del proyecto (ignorada por git).
# EN DESPLIEGUE debe apuntar a un VOLUMEN montado: si vive dentro del
# contenedor, los mapas se pierden al recrearlo.
# UPLOADS_DIR=/var/lib/pathfinder-vtt/uploads
